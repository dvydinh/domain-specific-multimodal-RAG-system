# ============================================================
# Domain-Specific Multimodal RAG System — Environment Config
# ============================================================
# Copy this file to .env and fill in your values.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ragpassword

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_TEXT_COLLECTION=recipe_text
QDRANT_IMAGE_COLLECTION=recipe_images

# --- Embedding Models (local) ---
TEXT_EMBEDDING_MODEL=BAAI/bge-m3
CLIP_MODEL=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k

# --- Ingestion ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
PDF_INPUT_DIR=data/raw
IMAGE_OUTPUT_DIR=data/images

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
