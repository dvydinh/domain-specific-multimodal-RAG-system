data/images/
data/raw/*.pdf
data/saga_outbox.db
data/.ingestion_checkpoint.json

# Model cache
models/
.cache/

# Logs and runtime traces
*.log
logs/
tmp/

# Node
node_modules/
frontend/dist/

# Database snapshots
qdrant_storage/
neo4j_data/

# Jupyter
.ipynb_checkpoints/

# Test artifacts
.pytest_cache/
htmlcov/
*.cover

# Debug/scratch files (should never be committed)
available_models*.txt
*_error*.log
